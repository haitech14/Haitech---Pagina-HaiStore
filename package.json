{
  "name": "haistore",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "HaiStore — tienda con React + Vite + Supabase",
  "scripts": {
    "dev": "vite",
    "dev:lan": "powershell -ExecutionPolicy Bypass -File scripts/open-dev-lan.ps1",
    "build": "tsc -b && vite build",
    "optimize:images": "node scripts/optimize-public-images.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "server": "node --watch server/index.js",
    "dev:all": "node scripts/print-dev-urls.mjs && concurrently -n web,api -c cyan,magenta \"vite\" \"npm run server\"",
    "sync:supabase": "node scripts/sync-supabase.mjs",
    "sync:product-images": "node scripts/sync-product-images.mjs",
    "sync:vercel-env": "node scripts/push-vercel-env.mjs",
    "db:migrate:005": "node scripts/apply-supabase-migration.mjs supabase/migrations/005_products_catalog_fields.sql",
    "import:persona-customers": "node scripts/import-persona-customers.mjs",
    "import:ventas-reports": "node scripts/import-ventas-reports.mjs",
    "haisales:sync": "node scripts/haisales-sync-seeds.mjs",
    "import:toner": "node scripts/import-toner-products.mjs",
    "import:toner-compatibles": "node scripts/import-compatible-toner-products.mjs",
    "import:processed-price-list": "node scripts/import-processed-price-list.mjs",
    "import:ricoh-lp": "node scripts/import-ricoh-lp-web.mjs",
    "merge:toner-originales": "node scripts/merge-toner-originales-into-toner.mjs",
    "patch:accesorios-images": "node scripts/patch-accesorios-images.mjs",
    "import:repuestos": "node scripts/import-repuestos-products.mjs",
    "auth:seed": "node scripts/seed-haitech-auth-users.mjs",
    "db:migrate:012": "node scripts/apply-supabase-migration.mjs supabase/migrations/012_haisales_mirror_tables.sql",
    "db:migrate:011": "node scripts/apply-supabase-migration.mjs supabase/migrations/011_imported_sale_documents.sql",
    "db:migrate:009": "node scripts/apply-supabase-migration.mjs supabase/migrations/009_store_customers_persona.sql"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@mdi/js": "^7.4.47",
    "@mdi/react": "^1.6.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "@tanstack/react-query": "^5.100.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "embla-carousel-auto-scroll": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "express": "^5.2.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.17.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "react-router-dom": "^7.16.0",
    "recharts": "^3.8.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "pg": "^8.21.0",
    "postcss": "^8.5.15",
    "svgo": "^4.0.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vite-plugin-image-optimizer": "^2.0.3"
  }
}

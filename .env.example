# --- Frontend (Vite) ---
# Solo variables con prefijo VITE_ se exponen al cliente.
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key
# Panel web HaiSupport (opcional; enlace en Haibot → Soporte)
# VITE_HAISUPPORT_APP_URL=https://soporte.haitech.pe
# Dominio canónico para SEO (canonical, Open Graph, sitemap)
# VITE_SITE_ORIGIN=https://www.haitech.pe
# Dejar vacío si la API va en el mismo dominio (Vercel: /api → serverless).
# Opcional: hosts extra para Vite en red local (coma-separados)
# VITE_ALLOWED_HOSTS=mi-pc.local,192.168.1.10
# VITE_DEV_PORT=5173

# --- Servidor admin (server/) ---
ADMIN_PORT=3080
# En producción incluye tu dominio Vercel, separado por comas.
CORS_ORIGIN=http://localhost:5173,https://haitech.pe,https://www.haitech.pe,https://haistore.vercel.app

# Credenciales de servidor para Supabase (NUNCA exponer al cliente).
# Auth unificado HaiStore + HaiSupport + HaiSales: mismo proyecto en las tres apps.
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Para aplicar migraciones SQL desde scripts (Account → Access Tokens):
# SUPABASE_ACCESS_TOKEN=sbp_...
# O URI de Postgres (Settings → Database → Connection string):
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@...

# Integración HaiSales (ERP) — base espejo Supabase + HaiStore.
# Por defecto usa SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY (mismo proyecto).
# Proyecto remoto opcional:
# HAISALES_API_URL=https://otro-proyecto.supabase.co
# HAISALES_API_KEY=service_role_del_proyecto_haisales
# HAISALES_TABLE_PERSONA=haisales_persona
# HAISALES_TABLE_VENTAS=haisales_ventas
# HAISALES_WEBHOOK_SECRET=secreto-compartido
# npm run haisales:sync
# Migración tablas espejo: supabase/migrations/012_haisales_mirror_tables.sql

# Integración HaiSupport (opcional; si vacío, usa SUPABASE_URL + SERVICE_ROLE_KEY).
# Para auth unificado: mismo proyecto Supabase en las tres apps.
# POST {HAISUPPORT_API_URL}/tickets — tickets de contacto (API REST dedicada)
# POST {HAISUPPORT_API_URL}/sync/{entity} — cambios HaiStore → HaiSupport (si SYNC enabled)
# GET /api/integrations/health — estado de conexión HaiSupport + HaiSales
# HAISUPPORT_API_URL=
# HAISUPPORT_API_KEY=
# Sincronizar cambios de inventario/clientes/cotizaciones/servicios/alquileres hacia HaiSupport API
HAISUPPORT_SYNC_ENABLED=true
# Secreto compartido para webhook HaiSupport → HaiStore (header X-HaiSupport-Secret)
HAISUPPORT_WEBHOOK_SECRET=

# Integración HaiSales (ERP) — por defecto usa SUPABASE_URL + SERVICE_ROLE_KEY
# HAISALES_API_URL=https://tu-proyecto.supabase.co
# HAISALES_API_KEY=service_role_key
# HAISALES_WEBHOOK_SECRET=secreto-compartido

# Fuente de datos compartida HaiStore ↔ HaiSupport (Supabase). Usar "file" solo en offline.
# HAISTORE_DATA_SOURCE=file
HAISTORE_CATALOG_SOURCE=supabase

# Checkout / pagos (Culqi + Mercado Pago)
# CULQI_PUBLIC_KEY=pk_test_...
# CULQI_SECRET_KEY=sk_test_...
# VITE_CULQI_PUBLIC_KEY=pk_test_...
# MERCADOPAGO_ACCESS_TOKEN=TEST-...
# CHECKOUT_PUBLIC_URL=https://www.haitech.pe

# Ver docs/haisupport-sync-contract.md

# Cuentas compartidas: shared/haitech-auth-credentials.json
# Sembrar en Supabase Auth: npm run auth:seed
# admin@haitech.pe / admin123 | soporte@haitech.pe / soporte123 | ventas@haitech.pe / demo123
# Ver docs/haitech-auth-unified.md
#
# Migración Supabase: ejecutar supabase/migrations/001_profiles_auth.sql
#
# --- Vercel (Panel → Settings → Environment Variables) ---
# Mismas claves que arriba para Production:
#   VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY
#   SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY
#   CORS_ORIGIN=https://haitech.pe,https://www.haitech.pe,https://haistore.vercel.app
# Opcional: HAISUPPORT_API_URL, HAISUPPORT_API_KEY
# HAISTORE_CATALOG_SOURCE=supabase|file (por defecto: supabase en Vercel, archivo en local)
#
# Sincronizar .env → Vercel: node scripts/push-vercel-env.mjs
# Migración catálogo: supabase/migrations/005_products_catalog_fields.sql

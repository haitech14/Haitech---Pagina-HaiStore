# --- Frontend (Vite) ---
# Solo variables con prefijo VITE_ se exponen al cliente.
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key
# Dejar vacío si la API va en el mismo dominio (Vercel: /api → serverless).
# VITE_API_BASE_URL=

# --- Servidor admin (server/) ---
ADMIN_PORT=3080
# En producción incluye tu dominio Vercel, separado por comas.
CORS_ORIGIN=http://localhost:5173,https://haistore.vercel.app

# Credenciales de servidor para Supabase (NUNCA exponer al cliente).
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Integración HaiSupport (opcional; vacío = modo demo).
HAISUPPORT_API_URL=
HAISUPPORT_API_KEY=

# Cuentas demo locales (sin Supabase): server/lib/auth-store.js
# admin@haitech.pe / admin123 | soporte@haitech.pe / demo123
# mayorista@haitech.pe / demo123
# corporativo@haitech.pe / demo123 | tecnico@haitech.pe / demo123
# distribuidor@haitech.pe / demo123 | vip@haitech.pe / demo123
#
# Migración Supabase: ejecutar supabase/migrations/001_profiles_auth.sql
#
# --- Vercel (Panel → Settings → Environment Variables) ---
# Mismas claves que arriba para Production:
#   VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY
#   SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY
#   CORS_ORIGIN=https://haistore.vercel.app
# Opcional: HAISUPPORT_API_URL, HAISUPPORT_API_KEY
